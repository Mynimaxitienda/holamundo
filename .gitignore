# --- DEPENDENCIAS ---
# Nunca subas la carpeta de librerías, es muy pesada y se genera con npm install
node_modules/
jspm_packages/

# --- COMPILACIÓN (BUILD) ---
# Archivos que se generan al hacer "npm run build"
dist/
dist-ssr/
*.queues
.svelte-kit/
.next/

# --- FIREBASE ---
# Archivos de configuración local y logs de Firebase
.firebase/
firebase-debug.log*
firestore-debug.log*
pubsub-debug.log*
ui-debug.log*
functions/node_modules/

# --- VARIABLES DE ENTORNO (SECRETOS) ---
# ¡IMPORTANTE! No subas tus llaves secretas de Firebase o APIs
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- SISTEMA Y LOGS ---
# Archivos temporales del sistema operativo o errores de npm
.DS_Store
thumbs.db
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs

# --- EDITOR ---
# Configuraciones locales de VS Code
.vscode/
*.swp
*.swo
